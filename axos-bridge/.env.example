# ===== AXOS Bridge (FastAPI) — 환경변수 예시 =====
# 실제 값은 .env 에 두고 절대 커밋하지 않는다 (.gitignore 처리됨).

# --- AXOS Bridge ---
AXOS_ENV=local
AXOS_API_KEY=change-me                  # 비우면 인증 비활성(로컬 전용)
AXOS_ALLOWED_ORIGINS=http://localhost:5173,https://*.base44.app,https://preview-sandbox--6a225124042c1a7db62f27fb.base44.app
BRIDGE_PORT=8000
LOG_LEVEL=INFO

# --- Databricks (미설정 시 status=offline, adapter는 skeleton 응답) ---
DATABRICKS_HOST=                        # 예: https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=                       # dapi...
DATABRICKS_CATALOG=axos_catalog
DATABRICKS_SCHEMA=gold
DATABRICKS_SQL_WAREHOUSE_ID=
DATABRICKS_MODEL_ENDPOINT=
DATABRICKS_VECTOR_ENDPOINT=
DATABRICKS_VECTOR_INDEX=
DATABRICKS_MCP_SERVER_URL=
DATABRICKS_MCP_AUTH_TOKEN=
DATABRICKS_ALLOW_WRITE=false            # true 일 때만 비-SELECT SQL 허용(allowlist)

# --- MX-Flow (n8n) — 로컬 n8n 재사용. MXFLOW_API_KEY 없으면 N8N_API_KEY(상위 axos/.env)로 폴백 ---
MXFLOW_BASE_URL=http://localhost:5678
MXFLOW_API_KEY=
MXFLOW_WEBHOOK_BASE_URL=http://localhost:5678/webhook
MXFLOW_WEBHOOK_SECRET=dev-local-token

# --- Storage / Logs ---
AUDIT_DB_URL=sqlite:///./axos_audit.db
